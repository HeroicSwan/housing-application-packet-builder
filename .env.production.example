# Intentionally incomplete production template. Startup fails until every required control is configured.
# Complete organizational privacy, legal, security, accessibility, vendor, and operations approvals first.
NODE_ENV="production"
DATABASE_URL="postgresql://hapb_app:replace-app-password@database:5432/hapb"
SYSTEM_DATABASE_URL="postgresql://hapb_system:replace-system-password@database:5432/hapb"
DATA_MODE="production"
PRODUCTION_DATA_ACKNOWLEDGEMENT="I_UNDERSTAND_REAL_DATA_REQUIRES_ORGANIZATIONAL_APPROVAL"
SESSION_SECRET="replace-with-a-high-diversity-secret-of-at-least-48-characters"
SETUP_BOOTSTRAP_TOKEN_HASH=""
INTERNAL_SERVICE_HOST_ALLOWLIST="clamav.internal,storage.internal,worker.internal"
APP_URL="https://housing-applications.example.org"
ENABLE_DEMO_LOGIN="false"
DEMO_BANNER="false"
SECURE_COOKIES="true"

# disabled keeps document review manual. Any live provider requires approval, credential, and approval ID.
DOCUMENT_PROCESSOR="disabled"
APPROVED_AI_PROVIDERS=""
AI_PROVIDER_APPROVAL_ID=""
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_HTTP_REFERER=""
OPENROUTER_APP_TITLE="Housing Application Packet Builder"
SAMBANOVA_API_KEY=""
SAMBANOVA_MODEL="Meta-Llama-3.3-70B-Instruct"
CEREBRAS_API_KEY=""
CEREBRAS_MODEL="gpt-oss-120b"
MISTRAL_API_KEY=""
MISTRAL_MODEL="mistral-small-latest"
DOCUMENT_PROCESSOR_TIMEOUT_MS="60000"

MAX_UPLOAD_MB="8"
STORAGE_PROVIDER="s3"
LOCAL_STORAGE_ROOT=".data/storage"
S3_BUCKET="replace-private-production-bucket"
S3_REGION="us-east-1"
S3_ENDPOINT=""
# Leave both blank for workload identity, or set both with organization-managed secrets.
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PRIVATE_BUCKET_ACKNOWLEDGEMENT="I_CONFIRMED_THE_PRODUCTION_BUCKET_IS_PRIVATE"

# Canonical Base64 for 32 random bytes from an organization-managed secret store.
DATA_ENCRYPTION_KEY=""
DATA_ENCRYPTION_KEY_ID="replace-with-unique-rotation-id"
DATA_ENCRYPTION_PREVIOUS_KEYS=""

SMTP_HOST="replace-with-approved-smtp-host"
SMTP_PORT="587"
SMTP_SECURE="true"
# Leave both blank only for an explicitly approved unauthenticated relay, or set both.
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="replace-with-organization-controlled-address@nonprofit.org"
SUBMISSION_TIMEOUT_MS="15000"

ENFORCE_PRODUCTION_CONFIG="true"
MALWARE_SCANNER="clamav"
CLAMAV_HOST="malware-scanner"
CLAMAV_PORT="3310"
MONITORING_TOKEN="replace-with-a-high-diversity-monitoring-token-of-at-least-48-characters"
CASE_RETENTION_DAYS="replace-with-approved-days"
DOCUMENT_RETENTION_DAYS="replace-with-approved-days"
AUDIT_RETENTION_DAYS="replace-with-approved-days"
AUDIT_LOGGING_ENABLED="true"
BACKUP_ENABLED="true"
BACKUP_DESTINATION="replace-with-private-encrypted-backup-destination"
BACKUP_RETENTION_DAYS="replace-with-approved-days"
WORKER_ENABLED="true"
WORKER_HEALTH_URL="http://worker:8787/health"
WORKER_HEALTH_PORT="8787"
MIGRATIONS_REQUIRED="true"
LOG_LEVEL="info"
DEFAULT_ADMIN_PASSWORD=""
SYNTHETIC_SEED_CONTEXT=""
