# Safe local profile: synthetic demonstration data only. Never enter real applicant information.
NODE_ENV="development"
DATABASE_URL="file:./dev.db"
SYSTEM_DATABASE_URL=""
DATA_MODE="synthetic"
PRODUCTION_DATA_ACKNOWLEDGEMENT=""
SESSION_SECRET="replace-with-at-least-32-random-characters"
SETUP_BOOTSTRAP_TOKEN_HASH=""
INTERNAL_SERVICE_HOST_ALLOWLIST=""
APP_URL="http://localhost:3000"
ENABLE_DEMO_LOGIN="true"
DEMO_BANNER="true"
SECURE_COOKIES="false"

# Deterministic mock extraction is local/demo only. Use disabled for production manual review.
DOCUMENT_PROCESSOR="mock"
APPROVED_AI_PROVIDERS=""
AI_PROVIDER_APPROVAL_ID=""
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_HTTP_REFERER=""
OPENROUTER_APP_TITLE="Housing Application Packet Builder"
SAMBANOVA_API_KEY=""
SAMBANOVA_MODEL="Meta-Llama-3.3-70B-Instruct"
CEREBRAS_API_KEY=""
CEREBRAS_MODEL="gpt-oss-120b"
MISTRAL_API_KEY=""
MISTRAL_MODEL="mistral-small-latest"
DOCUMENT_PROCESSOR_TIMEOUT_MS="60000"

MAX_UPLOAD_MB="8"
STORAGE_PROVIDER="local"
LOCAL_STORAGE_ROOT=".data/storage"
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PRIVATE_BUCKET_ACKNOWLEDGEMENT=""

# npm run setup replaces these two values only when it creates a new .env.
DATA_ENCRYPTION_KEY=""
DATA_ENCRYPTION_KEY_ID="local-development"
DATA_ENCRYPTION_PREVIOUS_KEYS=""

SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="no-reply@example.org"
SUBMISSION_TIMEOUT_MS="15000"

ENFORCE_PRODUCTION_CONFIG="false"
MALWARE_SCANNER="none"
CLAMAV_HOST="127.0.0.1"
CLAMAV_PORT="3310"
MONITORING_TOKEN=""
CASE_RETENTION_DAYS=""
DOCUMENT_RETENTION_DAYS=""
AUDIT_RETENTION_DAYS=""
AUDIT_LOGGING_ENABLED=""
BACKUP_ENABLED=""
BACKUP_DESTINATION=""
BACKUP_RETENTION_DAYS=""
WORKER_ENABLED=""
WORKER_HEALTH_URL=""
WORKER_HEALTH_PORT="8787"
MIGRATIONS_REQUIRED=""
LOG_LEVEL="info"
DEFAULT_ADMIN_PASSWORD=""
SYNTHETIC_SEED_CONTEXT=""
