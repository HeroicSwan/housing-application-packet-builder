{
  "name": "housing-application-packet-builder",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "doctor": "node scripts/doctor.mjs",
    "setup:ollama": "node scripts/setup-ollama.mjs",
    "ai:check": "node scripts/setup-ollama.mjs --check --verify",
    "ai:start": "node scripts/start-ollama.mjs",
    "ai:verify": "node --conditions=react-server --import tsx scripts/verify-local-ai.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "node --conditions=react-server --import tsx scripts/start-production.ts",
    "production:check": "node --conditions=react-server --import tsx scripts/start-production.ts --check",
    "config:production": "node --conditions=react-server --import tsx scripts/start-production.ts --config-only",
    "healthcheck": "node scripts/healthcheck.mjs",
    "open": "node scripts/open-local.mjs",
    "evaluate": "node --conditions=react-server --import tsx scripts/evaluate.ts",
    "evaluation:gold": "node scripts/check-gold-standard.mjs",
    "worker": "node --conditions=react-server --import tsx scripts/run-worker.ts",
    "worker:once": "node --conditions=react-server --import tsx scripts/run-worker.ts --once",
    "encryption:rotate": "node --conditions=react-server --import tsx scripts/rotate-encryption.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/run-e2e.mjs",
    "db:generate": "prisma generate",
    "db:generate:production": "node scripts/run-production-prisma.mjs generate",
    "db:validate:production": "node scripts/run-production-prisma.mjs validate",
    "db:setup": "node scripts/ensure-local-db.mjs && prisma db push --skip-generate && node scripts/ensure-local-organization.mjs && node scripts/seed-local-if-empty.mjs",
    "db:reset": "node scripts/reset-local-database.mjs",
    "demo:reset": "node scripts/reset-local-database.mjs",
    "db:deploy": "prisma migrate deploy",
    "fixtures:generate": "node scripts/generate-pdf-fixtures.mjs",
    "templates:accept": "node scripts/accept-acroform-template.mjs",
    "security:secrets": "node scripts/scan-secrets.mjs",
    "security:history": "node scripts/scan-git-history-secrets.mjs",
    "security:dependencies": "npm audit --audit-level=high",
    "secrets:generate": "node scripts/generate-production-secrets.mjs",
    "backup": "node scripts/backup-database.mjs",
    "backup:verify": "node scripts/verify-backup.mjs",
    "backup:restore": "node scripts/restore-backup.mjs",
    "validate": "node scripts/validate.mjs",
    "validate:live": "node scripts/run-service-gated-tests.mjs",
    "setup:blank": "node scripts/setup.mjs --blank",
    "db:setup:blank": "node scripts/ensure-local-db.mjs && prisma db push --skip-generate"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "overrides": {
    "postcss": "8.5.18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-slot": "^1.3.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "nodemailer": "^9.0.3",
    "otplib": "^13.4.1",
    "pdf-lib": "^1.17.1",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "19.2.8",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "open": "^11.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
