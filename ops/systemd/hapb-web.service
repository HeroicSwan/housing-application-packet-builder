[Unit]
Description=Housing Application Packet Builder web
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=hapb
Group=hapb
WorkingDirectory=/opt/hapb/current
EnvironmentFile=/etc/hapb/hapb.env
ExecStart=/usr/bin/npm run start
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/hapb

[Install]
WantedBy=multi-user.target
